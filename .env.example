# SkillHub 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# ===========================================
# API 地址配置（用于前端下载命令）
# ===========================================

# 方式 1：使用域名（推荐，可以隐藏真实 IP）
# 在 DNS 或 hosts 文件中配置 api.skillhub.local 指向服务器 IP
NEXT_PUBLIC_API_URL=http://api.skillhub.local/api/v1

# 方式 2：直接使用 IP 地址
# NEXT_PUBLIC_API_URL=http://192.168.1.100:8000/api/v1

# 方式 3：不配置，自动使用浏览器访问的地址
# 注释掉 NEXT_PUBLIC_API_URL 即可

# ===========================================
# 数据库配置
# ===========================================
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=skillhub
MYSQL_USER=skillhub
MYSQL_PASSWORD=skillhub_password

# ===========================================
# 其他配置
# ===========================================
SECRET_KEY=your-secret-key-change-in-production-please
DEBUG=false
